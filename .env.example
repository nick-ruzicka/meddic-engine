# MEDDIC Engine — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HUNTER_API_KEY=
TWITTER_API_KEY=           # TwitterAPI.io key
APIFY_API_TOKEN=           # For LinkedIn scraping
PROXYCURL_API_KEY=         # LinkedIn role search waterfall (~$0.01/lookup)

# Apify free-tier guardrails — keep small to preserve monthly credit
APIFY_MAX_SEARCH_QUERIES=2
APIFY_MAX_COMPANY_DOMAINS=3
APIFY_SEARCH_MAX_RESULTS=10
APIFY_COMPANY_MAX_RESULTS=5
APIFY_ENABLE_SEARCH_MODE=true
APIFY_ENABLE_COMPANY_MODE=true
EXA_API_KEY=               # For financial press signals

# ── App Config ────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=meddic-engine-dev
API_KEY=-demo-2026   # Dashboard auth header: X-API-Key
PORT=8765
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/.db
